MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=dietician_db
UPLOAD_DIR=../uploads

JWT_SECRET=dietician-agent-super-secret-key-2024
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

OLLAMA_URL=http://192.168.0.115:1234

# Stage 1 — Vision: extracts raw text from lab report images
VISION_MODEL=qwen2.5-vl-7b-instruct

# Stage 2 — Contemplation: validates, structures, and reasons about extracted data
CONTEMPLATION_MODEL=meta-llama-3.1-8b-instruct

# Stage 3 — Generation: creates the diet plan
TEXT_MODEL=meta-llama-3.1-8b-instruct

# Timeouts (in seconds)
OLLAMA_TIMEOUT=600

# App Settings
MAX_UPLOAD_SIZE_MB=50
MAX_PDF_PAGES=20
